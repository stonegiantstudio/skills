# seo-geo-aeo credentials — copy to your target project's .env (git-ignored).
# The skill reads ONLY these exact names; it never greps or dumps the
# environment to discover keys. Leave unset what you don't have — the skill
# asks before treating a source as unavailable, and can fall back to pasted
# screenshots. Never commit real values.

# Google Search Console (owned-site search truth)
GSC_PROPERTY=https://example.com
GSC_ACCESS_TOKEN=
# ...or a service-account JSON path instead of a token:
GSC_SERVICE_ACCOUNT_JSON=

# Google Analytics 4 (traffic, engagement, AI-referral signal)
GA4_PROPERTY_ID=
GA4_ACCESS_TOKEN=
GA4_SERVICE_ACCOUNT_JSON=

# PageSpeed Insights (Core Web Vitals / technical) — a key lifts the tiny
# anonymous quota that the skill will otherwise exhaust quickly.
PAGESPEED_API_KEY=

# DataForSEO (one account ≈ SERP + keyword volume + competitor backlinks + AI-
# answer citations — the cheap fill for the whole portfolio). Login + password from
# the dashboard's API CREDENTIALS block (the API password may differ from your
# login). Core APIs are pay-per-use; the Backlinks API and LLM Mentions endpoints
# each require a $100/mo activation — optional add-ons; leave unset to fall back to
# Ahrefs/Semrush (backlinks) or the manual AI-citation protocol (see the connector).
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Third-party authority / keyword data (optional, paid — Semrush/Ahrefs subscriptions)
SEMRUSH_API_KEY=
AHREFS_API_TOKEN=

# AI-answer visibility tracking (optional, paid)
OTTERLY_API_KEY=
